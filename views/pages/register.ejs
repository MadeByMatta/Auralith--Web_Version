<%- include('../partials/header') %>

    <div class="auth-wrapper animate-fade-in">
        <div class="auth-card">
            <h2 class="auth-title">Crear Cuenta</h2>
            <p class="auth-subtitle">Únete a AURALITH y descubre un nuevo mundo musical</p>

            <% if (typeof error !=='undefined' ) { %>
                <div
                    style="color: var(--error-color); margin-bottom: 2rem; font-size: 0.9rem; background: #48c3cb; padding: 0.45rem; border-radius: 10px;">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/register" method="POST">
                        <div class="form-group">
                            <label for="nombre_usuario" class="form-label">Nombre de Usuario</label>
                            <input type="text" id="nombre_usuario" name="nombre_usuario" class="form-control" required
                                placeholder="tu_usuario">
                        </div>

                        <div class="form-group">
                            <label for="email" class="form-label">Correo Electrónico</label>
                            <input type="email" id="email" name="email" class="form-control" required
                                placeholder="tu@correo.com">
                        </div>

                        <div class="form-group" style="margin-bottom: 2rem;">
                            <label for="password" class="form-label">Contraseña</label>
                            <input type="password" id="password" name="password" class="form-control" required
                                placeholder="••••••••">
                        </div>

                        <button type="submit" class="btn btn-primary btn-block"
                            style="font-size: 1.1rem;">Registrarse</button>
                    </form>

                    <div class="form-text">
                        ¿Ya tienes cuenta? <a href="/login" style="font-weight: 600;">Inicia sesión</a>
                    </div>
        </div>
    </div>

    <%- include('../partials/footer') %>